# Logging verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# INFO logs every user message, tool call (args/decision/result), and agent turn.
LOG_LEVEL=INFO

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user ids allowed to talk to the bot (get yours from @userinfobot)
ALLOWED_USER_IDS=

# Pydantic AI model identifier, e.g. google:gemini-3-flash-preview, openai:gpt-5.4, openrouter:<vendor/model>
# Must be multimodal (accepts image input) since it's also used for photo-based meal logging.
LLM_MODEL=google:gemini-3-flash-preview

# One of these is required, matching the provider used by LLM_MODEL.
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Streamable-HTTP MCP servers. Leave empty to run with no tools.
# Either a comma-separated list of URLs (no auth), or a JSON array of
# {"url": "...", "headers": {...}} objects for servers that need auth headers, e.g.:
# MCP_SERVERS='[{"url": "https://example.com/mcp", "headers": {"Authorization": "Basic ..."}}]'
MCP_SERVERS=http://127.0.0.1:8765/mcp

# Comma-separated tool names that run without a Telegram Approve/Deny prompt
# (e.g. read-only lookups). Leave empty to require approval for every tool.
AUTO_APPROVE_TOOLS=

# Path to the SQLite database file
DATABASE_PATH=nutrition.db